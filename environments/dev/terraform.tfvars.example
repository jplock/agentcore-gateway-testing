region = "us-east-1"
name   = "agentcore-dev"

# AWS CLI/SSO profile (default: dev-admin). Set to "" to use env-var credentials.
# aws_profile = "dev-admin"

# Default inbound auth is AWS_IAM. To use JWT instead, uncomment:
# authorizer_type = "CUSTOM_JWT"
# jwt_authorizer = {
#   discovery_url    = "https://YOUR_IDP/.well-known/openid-configuration"
#   allowed_audience = ["your-audience"]
#   allowed_clients  = ["your-client-id"]
# }

tags = {
  Owner = "platform-team"
}
